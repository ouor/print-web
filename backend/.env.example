# Copy to .env and fill in values
PORT=8000

# Admin login: bcrypt hash of the chosen admin password.
# Generate with:  python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# Session cookie signing key (32+ random bytes).
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Printer used by the worker. Leave empty to use the Windows default printer.
PRINTER_NAME=Samsung CLX-6240 Series PS

# How long to keep uploaded images after a job reaches a terminal state.
RETENTION_DAYS=7

# Upload size limit per request (megabytes).
UPLOAD_MAX_MB=15

# Storage
DATABASE_URL=sqlite:///./data.db
UPLOAD_DIR=./uploads
