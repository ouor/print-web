# Copy to .env and fill in values
PORT=8000

# Admin login: bcrypt hash of the chosen admin password.
# Generate with:  python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# Session cookie signing key (32+ random bytes).
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Printer(s) used by the worker pool. Comma-separated for multiple
# printers — one worker task per printer, with jobs routed to whichever
# is idle. Leave empty to be prompted at startup (or auto-fall-back to
# the Windows default if no TTY).
#   PRINTER_NAME=Samsung CLX-8380 Series PS
#   PRINTER_NAME=Samsung CLX-8380 Series PS,HP Business Inkjet 3000 PS
PRINTER_NAME=Samsung CLX-6240 Series PS

# Real photo paper size (mm). At startup, the app probes the driver's
# mechanical margins at this size and pushes a slightly larger DEVMODE so
# the printable area equals the real paper, giving edge-to-edge prints.
# Default is 4x6 inches landscape.
PRINT_PAPER_LONG_MM=152.4
PRINT_PAPER_SHORT_MM=101.6

# How long to keep uploaded images after a job reaches a terminal state.
RETENTION_DAYS=7

# Upload size limit per request (megabytes).
UPLOAD_MAX_MB=15

# Storage
DATABASE_URL=sqlite:///./data.db
UPLOAD_DIR=./uploads

# Set to true when serving behind HTTPS (e.g. through your tunnel).
SESSION_SECURE=false
